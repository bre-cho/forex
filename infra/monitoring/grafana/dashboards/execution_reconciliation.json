{
  "title": "Execution & Reconciliation",
  "uid": "forex-execution-reconciliation",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "title": "Order Submit Latency P50/P95/P99 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(order_submit_latency_ms_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(order_submit_latency_ms_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(order_submit_latency_ms_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "UNKNOWN Orders Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(order_unknown_total)",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Reconciliation Queue Depth",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "reconciliation_queue_depth",
          "legendFormat": "depth"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Reconciliation Overdue (escalated)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(reconciliation_overdue_total[5m])",
          "legendFormat": "bot={{ bot_id }}"
        }
      ]
    },
    {
      "title": "Reconciliation Resolved",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(reconciliation_resolved_total[5m])",
          "legendFormat": "code={{ resolution_code }}"
        }
      ]
    },
    {
      "title": "Order Placed vs Rejected",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(order_placed_total[5m])",
          "legendFormat": "placed"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(order_rejected_total[5m])",
          "legendFormat": "rejected"
        }
      ]
    },
    {
      "title": "Order Slippage Pips P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(order_slippage_pips_bucket[5m]))",
          "legendFormat": "p95 slippage"
        }
      ]
    }
  ]
}
