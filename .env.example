# ═══════════════════════════════════════════════════════════════════════════
#  Robot Forex — cTrader Live Credentials
#  Sao chép file này thành .env rồi điền thông tin thực của bạn:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════

# ── Bước 1: Đăng ký ứng dụng cTrader Open API ──────────────────────────────
# Truy cập: https://connect.spotware.com/apps
# → Tạo một ứng dụng mới (miễn phí)
# → Sau khi tạo xong, bạn sẽ nhận được Client ID và Client Secret bên dưới.

CTRADER_CLIENT_ID=your_app_client_id_here
CTRADER_CLIENT_SECRET=your_app_client_secret_here

# ── Bước 2: Lấy Access Token & Refresh Token (OAuth2) ─────────────────────
# Mở trình duyệt và truy cập URL dưới đây (thay YOUR_CLIENT_ID và YOUR_REDIRECT_URI):
#
#   https://connect.spotware.com/apps/auth?client_id=YOUR_CLIENT_ID
#     &redirect_uri=YOUR_REDIRECT_URI
#     &response_type=code
#     &scope=trading
#
# Sau khi đăng nhập, bạn sẽ được redirect đến:
#   YOUR_REDIRECT_URI?code=AUTHORIZATION_CODE
#
# Dùng code đó để lấy tokens (thay các giá trị tương ứng):
#   curl -X POST https://connect.spotware.com/apps/token \
#     -d "grant_type=authorization_code" \
#     -d "code=AUTHORIZATION_CODE" \
#     -d "client_id=YOUR_CLIENT_ID" \
#     -d "client_secret=YOUR_CLIENT_SECRET" \
#     -d "redirect_uri=YOUR_REDIRECT_URI"
#
# Response trả về: { "access_token": "...", "refresh_token": "...", "expires_in": 3600 }

CTRADER_ACCESS_TOKEN=your_oauth2_access_token_here
CTRADER_REFRESH_TOKEN=your_oauth2_refresh_token_here

# ── Bước 3: Điền thông tin tài khoản giao dịch ─────────────────────────────
# Login (Account ID) của bạn — xem trong cTrader platform → Account → Account ID
CTRADER_ACCOUNT_ID=YOUR_ACCOUNT_ID_HERE

# ── Bước 4: Cấu hình symbol và khung thời gian ─────────────────────────────
# Tên symbol phải khớp chính xác với tên trên nền tảng của broker
# (vd: EURUSD, GBPUSD, XAUUSD, BTCUSD, …)
CTRADER_SYMBOL=EURUSD
CTRADER_TIMEFRAME=M5

# ── Bước 5: Chọn môi trường ──────────────────────────────────────────────────
# true  = tài khoản LIVE  (kết nối tới live.ctraderapi.com:5035)
# false = tài khoản DEMO  (kết nối tới demo.ctraderapi.com:5035)
CTRADER_LIVE=true

# ════════════════════════════════════════════════════════════════════════════
#  LƯU Ý BẢO MẬT
#  - KHÔNG commit file .env lên git (đã được thêm vào .gitignore)
#  - Refresh token sẽ tự động được gia hạn — robot cập nhật trong bộ nhớ
#  - Access token hết hạn sau 1 giờ — robot tự làm mới khi còn < 5 phút
# ════════════════════════════════════════════════════════════════════════════
