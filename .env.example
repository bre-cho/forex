# ═══════════════════════════════════════════════════════════════════════════
#  Forex Trading Platform — Environment Variables
#  Copy this file: cp .env.example .env
#  Never commit the .env file to git.
# ═══════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME="Forex Trading Platform"
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
SECRET_KEY=change_me_to_a_long_random_string_in_production
JWT_SECRET=change_me_to_another_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
DEBUG=true
LOG_LEVEL=INFO

# ── Production Safety Gates ───────────────────────────────────────────────────
# Set APP_ENV=production + IS_PRODUCTION=true in prod deployments.
# These flags enable fail-closed guards throughout the system.
#
# IS_PRODUCTION=true
# LIVE_BURN_IN_REQUIRED=true        # require burn-in before first live start
# ALLOW_STUB_RUNTIME=false          # forbid mock/paper providers in live mode
# ENABLE_LEGACY_ROUTES=false        # disable legacy /api/* routes
# REQUIRE_SIGNED_GATE_CONTEXT=true  # require HMAC-signed pre-execution gate context
# LIVE_CERT_MAX_AGE_HOURS=168       # provider certification TTL (hours)
#
# FROZEN_CONTEXT_HMAC_SECRET=<min-32-char-random>  # HMAC key for gate context signing
#
# Production secret generation:
#   SECRET_KEY:    python -c "import secrets; print(secrets.token_hex(32))"
#   JWT_SECRET:    python -c "import secrets; print(secrets.token_hex(32))"
#   FERNET_KEY:    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   FROZEN_CONTEXT_HMAC_SECRET: python -c "import secrets; print(secrets.token_hex(32))"

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://forex:forex_dev@localhost:5432/forex_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
SQLITE_DATABASE_URL=sqlite:///./forex.db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ── cTrader Credentials ──────────────────────────────────────────────────────
CTRADER_CLIENT_ID=your_app_client_id_here
CTRADER_CLIENT_SECRET=your_app_client_secret_here
CTRADER_ACCESS_TOKEN=your_oauth2_access_token_here
CTRADER_REFRESH_TOKEN=your_oauth2_refresh_token_here
CTRADER_ACCOUNT_ID=YOUR_ACCOUNT_ID_HERE
CTRADER_SYMBOL=EURUSD
CTRADER_TIMEFRAME=M5
CTRADER_LIVE=false

# ── LLM / AI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
LLM_PROVIDER=openai
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@yourplatform.com
SMTP_FROM_NAME="Forex Platform"
SMTP_TLS=true
SMTP_SSL=false

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
PROMETHEUS_ENABLED=true

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── WebSocket hardening ──────────────────────────────────────────────────────
WS_IDLE_TIMEOUT_SECONDS=90
WS_MAX_CONNECTIONS_PER_USER=10
WS_MAX_CONNECTIONS_PER_USER_PER_WORKSPACE=5

# ── Credentials encryption ────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Optional previous keys for rotation (comma-separated, oldest -> newest)
FERNET_KEY_PREVIOUS=

# ── Discord (optional notifications) ─────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── MT5 Gateway (Linux deployment) ───────────────────────────────────────────
# MT5 requires a Windows host (DLL).  In Linux deployments route MT5 calls
# through an HTTP gateway service running on a dedicated Windows VM or Wine
# container.  The execution-service will forward orders to this URL.
# MT5_GATEWAY_URL=http://mt5-gateway:8080
# MT5_GATEWAY_API_KEY=<api-key-for-gateway>

# ── Worker Configuration ──────────────────────────────────────────────────────
# These workers run as separate processes in production (see docker-compose.prod.yml):
#   - reconciliation-worker  : unknown-order daemon, runs every 10 s
#   - integrity-worker       : nightly ledger integrity check
#   - submit-outbox-recovery : recovers stuck submit-phase orders
ENABLE_RECONCILIATION_DAEMON=true
ENABLE_SUBMIT_OUTBOX_RECOVERY_WORKER=true
INTEGRITY_RUN_HOUR_UTC=0
INTEGRITY_RUN_MINUTE_UTC=15
INTEGRITY_RUN_ON_STARTUP=true
